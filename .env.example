# Copy to .env.local for local dev. Production template: .env.production
# (.env* is gitignored except this file)

# Neon Postgres connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Stripe — use TEST keys locally, LIVE keys in Vercel production
# https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
# Local: from `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# Production: from Stripe Dashboard → Webhooks → signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# Public base URL (no trailing slash)
# Local: http://localhost:3000
# Production: https://wepray2flourish.net
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Admin CRM auth ────────────────────────────────────────────
SESSION_SECRET=""
# Local dev:
ADMIN_PASSWORD=""
# Production (Vercel) — use hash only, omit ADMIN_PASSWORD:
# ADMIN_PASSWORD_HASH=""
# Hash: node -e "console.log(require('crypto').createHash('sha256').update(process.argv[1]).digest('hex'))" 'yourpassword'

# ── Resend email (purchase + newsletter notifications) ────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="We Pray To Flourish <hello@wepray2flourish.net>"
ADMIN_NOTIFICATION_EMAIL="you@email.com"

# Optional test script defaults
# TEST_NEWSLETTER_EMAIL=""
# TEST_ORDER_EMAIL=""