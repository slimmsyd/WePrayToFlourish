# Copy to .env.local and fill in. (.env* is gitignored.)
# This file documents every env var the app needs — safe to commit (no secrets).

# Neon Postgres connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Stripe TEST keys — https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
# From `stripe listen` (local) or the Dashboard webhook endpoint
STRIPE_WEBHOOK_SECRET="whsec_..."

# Public base URL (Stripe return_url, OG/Twitter image URLs). Use localhost locally;
# set to https://wepray2flourish.net in production (localhost is ignored there).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Admin CRM auth ────────────────────────────────────────────
# HMAC key for the admin session cookie. REQUIRED. Generate: openssl rand -hex 32
SESSION_SECRET=""
# Admin login password. Prefer the HASH in production and omit the plaintext.
# Hash: node -e "console.log(require('crypto').createHash('sha256').update(process.argv[1]).digest('hex'))" 'yourpassword'
ADMIN_PASSWORD=""
# ADMIN_PASSWORD_HASH=""   # sha256 hex; if set, takes precedence over ADMIN_PASSWORD
